{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "RangeSelector",
  "version": "0.1.0",
  "identifier": "com.jasonhong.rangeselector",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "RangeSelector",
        "width": 500,
        "height": 350,
        "minWidth": 400,
        "minHeight": 300,
        "decorations": false,
        "transparent": true
      },
      {
        "label": "selection-window",
        "url": "/",
        "title": "Selection",
        "fullscreen": true,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false
      },
      {
        "label": "history-window",
        "url": "/?window=history",
        "title": "History",
        "width": 700,
        "height": 550,
        "minWidth": 400,
        "minHeight": 300,
        "transparent": true,
        "decorations": false,
        "center": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
